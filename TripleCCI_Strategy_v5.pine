// https://mozilla.org/MPL/2.0/
// Triple CCI Strategy v5 — PF~2 穩定高報酬版
// 最佳化：357,824 組合，目標 PF 1.5~2.5 + 最高報酬 + 最低 MDD
// 最佳：CCI 14/20/50, Th20, SL2.5, TP2.8, Trail20, ADX≥15, EMA200 ON

//@version=5
strategy("Triple CCI v5", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.0, slippage=0, initial_capital=100000, pyramiding=0, calc_on_every_tick=false)

// ═══════════════════════════════════════════════
//  輸入參數（357K 組合最佳化結果）
// ═══════════════════════════════════════════════

i_startDate = input.time(timestamp("2022-01-01 00:00"), "Trade Start", group="TRADING PERIOD")
i_stopDate  = input.time(timestamp("2026-12-31 00:00"), "Trade Stop",  group="TRADING PERIOD")
inDateRange = time >= i_startDate and time <= i_stopDate

// ── CCI（最佳化：14/20/50，更快反應）──
i_cciFast      = input.int(14,  "CCI Fast",               minval=5,  maxval=50,  group="CCI")
i_cciMid       = input.int(20,  "CCI Middle",             minval=10, maxval=80,  group="CCI")
i_cciSlow      = input.int(50,  "CCI Slow",               minval=20, maxval=150, group="CCI")
i_cciThreshold = input.int(20,  "CCI Momentum Threshold", minval=0,  maxval=200, tooltip="20=更多進場機會", group="CCI")
i_cciSlowTh    = input.int(0,   "CCI Slow Min Magnitude", minval=0,  maxval=200, tooltip="0=只要同向即可", group="CCI")

// ── ADX ──
i_adxLength = input.int(14,   "ADX Length",    minval=5,  maxval=50, group="ADX")
i_adxMin    = input.int(15,   "ADX Min Trend", minval=0,  maxval=50, group="ADX")

// ── EMA（最佳化：趨勢50 追蹤20 方向200）──
i_emaTrend = input.int(50,  "EMA Trend",      minval=10, maxval=200, group="EMA")
i_emaTrail = input.int(20,  "Trailing EMA",   minval=5,  maxval=100, group="EMA")
i_emaSlow  = input.int(200, "EMA Slow (方向)", minval=50, maxval=400, group="EMA")

// ── MFI ──
i_mfiLength = input.int(14, "MFI Length", minval=5, maxval=50, group="MFI")

// ── ATR（最佳化：SL=2.5 TP=2.8）──
i_atrPeriod = input.int(14,    "ATR Period",            minval=5,   maxval=50,   group="ATR")
i_atrSL     = input.float(2.5, "ATR Stop Loss",         minval=0.5, maxval=5.0,  step=0.1, group="ATR")
i_atrTP     = input.float(2.8, "ATR Trail Activation",  minval=1.0, maxval=10.0, step=0.1, group="ATR")

// ── 過濾器 ──
i_minScore     = input.int(5,     "Min Score (3~5)",  minval=3, maxval=5, group="FILTERS")
i_minATR       = input.float(5.0, "Min ATR",          minval=0, maxval=100, step=1.0, group="FILTERS")
i_cooldownBars = input.int(2,     "Cooldown Bars",    minval=0, maxval=20, group="FILTERS")

// ── 穩定性 ──
i_useEMA200     = input.bool(true, "EMA 200 方向過濾", group="STABILITY")
i_useLossLimit  = input.bool(true, "連虧保護",         group="STABILITY")
i_maxConsecLoss = input.int(3,     "最大連續虧損",      minval=2, maxval=10, group="STABILITY")
i_lossPauseBars = input.int(10,    "連虧暫停 K 棒",     minval=3, maxval=50, group="STABILITY")

// ═══════════════════════════════════════════════
//  指標
// ═══════════════════════════════════════════════

cciFast = ta.cci(close, i_cciFast)
cciMid  = ta.cci(close, i_cciMid)
cciSlow = ta.cci(close, i_cciSlow)

emaTrend = ta.ema(close, i_emaTrend)
emaTrail = ta.ema(close, i_emaTrail)
emaSlow  = ta.ema(close, i_emaSlow)
atrValue = ta.atr(i_atrPeriod)

[diplus, diminus, adxValue] = ta.dmi(i_adxLength, i_adxLength)
adxOK = adxValue >= i_adxMin

hasTrueVolume = ta.cum(volume) > 0
trueMFI = ta.mfi(hlc3, i_mfiLength)
pseudoDir   = (high - low) != 0 ? (close - open) / (high - low) : 0.0
pseudoMag   = high - low
pseudoPos   = pseudoDir > 0 ? pseudoDir * pseudoMag : 0.0
pseudoNeg   = pseudoDir < 0 ? math.abs(pseudoDir) * pseudoMag : 0.0
pseudoPosMA = ta.sma(pseudoPos, i_mfiLength)
pseudoNegMA = ta.sma(pseudoNeg, i_mfiLength)
pseudoTotal = pseudoPosMA + pseudoNegMA
pseudoMFI   = pseudoTotal > 0 ? (pseudoPosMA / pseudoTotal) * 100 : 50.0
mfiValue    = hasTrueVolume ? trueMFI : pseudoMFI

atrOK   = atrValue >= i_minATR
ema200B = not i_useEMA200 or close > emaSlow
ema200S = not i_useEMA200 or close < emaSlow

// ═══════════════════════════════════════════════
//  Cooldown & 連虧保護
// ═══════════════════════════════════════════════
var int barsSinceExit  = 999
var int consecLosses   = 0
var int lossPauseUntil = 0

if strategy.position_size == 0
    barsSinceExit += 1
else
    barsSinceExit := 0

if strategy.position_size == 0 and strategy.position_size[1] != 0
    barsSinceExit := 0

cooldownOK  = barsSinceExit >= i_cooldownBars
lossPauseOK = not i_useLossLimit or bar_index >= lossPauseUntil

// ═══════════════════════════════════════════════
//  進場條件
// ═══════════════════════════════════════════════

longCCI1  = ta.crossover(cciFast, 0) and cciFast > i_cciThreshold
longCCI2  = cciMid > 0
longCCI3  = cciSlow > i_cciSlowTh
longTrend = close > emaTrend
longMFI   = mfiValue > 40

longScore = (longCCI1 ? 1 : 0) + (longCCI2 ? 1 : 0) + (longCCI3 ? 1 : 0) + (longTrend ? 1 : 0) + (longMFI ? 1 : 0)
longEntry = longScore >= i_minScore and longCCI1 and atrOK and cooldownOK and adxOK and ema200B and lossPauseOK

shortCCI1  = ta.crossunder(cciFast, 0) and cciFast < -i_cciThreshold
shortCCI2  = cciMid < 0
shortCCI3  = cciSlow < -i_cciSlowTh
shortTrend = close < emaTrend
shortMFI   = mfiValue < 60

shortScore = (shortCCI1 ? 1 : 0) + (shortCCI2 ? 1 : 0) + (shortCCI3 ? 1 : 0) + (shortTrend ? 1 : 0) + (shortMFI ? 1 : 0)
shortEntry = shortScore >= i_minScore and shortCCI1 and atrOK and cooldownOK and adxOK and ema200S and lossPauseOK

exitLongSignal  = ta.crossunder(cciFast, 0)
exitShortSignal = ta.crossover(cciFast, 0)

// ═══════════════════════════════════════════════
//  追蹤止盈
// ═══════════════════════════════════════════════
var float entryPrice        = na
var float stopLossPrice     = na
var bool  trailingActive    = false
var float trailingStopPrice = na
var float entryATR          = na

if strategy.position_size > 0
    floatPnl = close - entryPrice
    tpDist   = entryATR * i_atrTP
    if not trailingActive and floatPnl >= tpDist
        trailingActive    := true
        trailingStopPrice := emaTrail
    if trailingActive
        trailingStopPrice := math.max(nz(trailingStopPrice), emaTrail)

else if strategy.position_size < 0
    floatPnl = entryPrice - close
    tpDist   = entryATR * i_atrTP
    if not trailingActive and floatPnl >= tpDist
        trailingActive    := true
        trailingStopPrice := emaTrail
    if trailingActive
        trailingStopPrice := math.min(nz(trailingStopPrice, 1e10), emaTrail)

else
    trailingActive    := false
    trailingStopPrice := na

// ═══════════════════════════════════════════════
//  策略執行
// ═══════════════════════════════════════════════

if longEntry and inDateRange and strategy.position_size == 0
    sl = close - atrValue * i_atrSL
    strategy.entry("Long", strategy.long)
    strategy.exit("Long SL", "Long", stop=sl)
    entryPrice        := close
    stopLossPrice     := sl
    entryATR          := atrValue
    trailingActive    := false
    trailingStopPrice := na

if shortEntry and inDateRange and strategy.position_size == 0
    sl = close + atrValue * i_atrSL
    strategy.entry("Short", strategy.short)
    strategy.exit("Short SL", "Short", stop=sl)
    entryPrice        := close
    stopLossPrice     := sl
    entryATR          := atrValue
    trailingActive    := false
    trailingStopPrice := na

// 追蹤止盈
if strategy.position_size > 0 and trailingActive and not na(trailingStopPrice)
    if low <= trailingStopPrice
        strategy.close("Long", comment="Trail TP")

if strategy.position_size < 0 and trailingActive and not na(trailingStopPrice)
    if high >= trailingStopPrice
        strategy.close("Short", comment="Trail TP")

// CCI 出場 + 連虧追蹤
if strategy.position_size > 0 and exitLongSignal
    pnl = close - entryPrice
    if pnl < 0
        consecLosses += 1
        if i_useLossLimit and consecLosses >= i_maxConsecLoss
            lossPauseUntil := bar_index + i_lossPauseBars
            consecLosses   := 0
    else
        consecLosses := 0
    strategy.close("Long", comment="CCI Exit")

if strategy.position_size < 0 and exitShortSignal
    pnl = entryPrice - close
    if pnl < 0
        consecLosses += 1
        if i_useLossLimit and consecLosses >= i_maxConsecLoss
            lossPauseUntil := bar_index + i_lossPauseBars
            consecLosses   := 0
    else
        consecLosses := 0
    strategy.close("Short", comment="CCI Exit")

// SL hit 連虧
if strategy.position_size == 0 and strategy.position_size[1] != 0
    if not exitLongSignal and not exitShortSignal
        consecLosses += 1
        if i_useLossLimit and consecLosses >= i_maxConsecLoss
            lossPauseUntil := bar_index + i_lossPauseBars
            consecLosses   := 0

// ═══════════════════════════════════════════════
//  視覺化
// ═══════════════════════════════════════════════
plot(emaTrend, "EMA 50",  color=color.new(color.orange, 30), linewidth=2)
plot(emaSlow,  "EMA 200", color=color.new(color.purple, 40), linewidth=2)
plot(emaTrail, "Trail",   color=color.new(color.gray, 60),   linewidth=1, style=plot.style_stepline)
plot(trailingActive ? trailingStopPrice : na, "Trailing Stop", color=color.new(color.lime, 0), linewidth=2, style=plot.style_stepline)

plotshape(longEntry  and strategy.position_size == 0 and inDateRange, "Long",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(shortEntry and strategy.position_size == 0 and inDateRange, "Short", shape.triangledown, location.abovebar, color.new(color.red, 0),   size=size.small)

trendBull = cciFast > 0 and cciMid > 0 and cciSlow > 0 and adxOK
trendBear = cciFast < 0 and cciMid < 0 and cciSlow < 0 and adxOK
bgcolor(trendBull ? color.new(color.green, 93) : trendBear ? color.new(color.red, 93) : na)
bgcolor(adxValue < i_adxMin ? color.new(color.gray, 95) : na, title="Ranging")

var table t = table.new(position.top_right, 3, 8, bgcolor=color.new(color.black, 85), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "Indicator", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Value",     text_color=color.white, text_size=size.small)
    table.cell(t, 2, 0, "Status",    text_color=color.white, text_size=size.small)

    table.cell(t, 0, 1, "CCI 14", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(cciFast, "#.0"), text_color=cciFast > 0 ? color.green : color.red, text_size=size.small)
    table.cell(t, 2, 1, math.abs(cciFast) > 50 ? "Strong" : "Normal", text_color=math.abs(cciFast) > 50 ? color.green : color.gray, text_size=size.small)

    table.cell(t, 0, 2, "CCI 20", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(cciMid, "#.0"), text_color=cciMid > 0 ? color.green : color.red, text_size=size.small)
    table.cell(t, 2, 2, cciMid > 0 ? "Bull" : "Bear", text_color=cciMid > 0 ? color.green : color.red, text_size=size.small)

    table.cell(t, 0, 3, "CCI 50", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(cciSlow, "#.0"), text_color=cciSlow > 0 ? color.green : color.red, text_size=size.small)
    table.cell(t, 2, 3, cciSlow > 0 ? "Aligned" : "Counter", text_color=cciSlow > 0 ? color.green : color.red, text_size=size.small)

    table.cell(t, 0, 4, "ADX", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(adxValue, "#.0"), text_color=adxOK ? color.green : color.orange, text_size=size.small)
    table.cell(t, 2, 4, adxOK ? "Trend" : "Range", text_color=adxOK ? color.green : color.orange, text_size=size.small)

    table.cell(t, 0, 5, "EMA 200", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(emaSlow, "#.0"), text_color=close > emaSlow ? color.green : color.red, text_size=size.small)
    table.cell(t, 2, 5, close > emaSlow ? "Above" : "Below", text_color=close > emaSlow ? color.green : color.red, text_size=size.small)

    table.cell(t, 0, 6, "MFI", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(mfiValue, "#.0"), text_color=mfiValue > 50 ? color.green : color.red, text_size=size.small)
    table.cell(t, 2, 6, mfiValue > 50 ? "Inflow" : "Outflow", text_color=mfiValue > 50 ? color.green : color.red, text_size=size.small)

    table.cell(t, 0, 7, "Losses", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(consecLosses), text_color=consecLosses >= 2 ? color.red : color.white, text_size=size.small)
    table.cell(t, 2, 7, bar_index < lossPauseUntil ? "PAUSED" : "Active", text_color=bar_index < lossPauseUntil ? color.orange : color.green, text_size=size.small)

alertcondition(longEntry and strategy.position_size == 0, title="Long", message="CCI v5 LONG")
alertcondition(shortEntry and strategy.position_size == 0, title="Short", message="CCI v5 SHORT")
