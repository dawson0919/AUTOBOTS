// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// Triple CCI Strategy v4b — V3 基礎 + ADX 過濾 + 最佳化參數
// 最佳化來源：27648 組合回測，加權評分（報酬+PF+勝率-MDD）

//@version=5
strategy("Triple CCI v4b", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.0, slippage=0, initial_capital=100000, pyramiding=0, calc_on_every_tick=false)

// ═══════════════════════════════════════════════
//  輸入參數（最佳化後預設值）
// ═══════════════════════════════════════════════

// ── 交易期間 ──
i_startDate = input.time(timestamp("2022-01-01 00:00"), "Trade Start", group="TRADING PERIOD")
i_stopDate  = input.time(timestamp("2026-12-31 00:00"), "Trade Stop",  group="TRADING PERIOD")
inDateRange = time >= i_startDate and time <= i_stopDate

// ── CCI（最佳化：14/25/80）──
i_cciFast      = input.int(14,  "CCI Fast",               minval=5,   maxval=50,  group="CCI")
i_cciMid       = input.int(25,  "CCI Middle",             minval=10,  maxval=80,  group="CCI")
i_cciSlow      = input.int(80,  "CCI Slow",               minval=20,  maxval=150, group="CCI")
i_cciThreshold = input.int(50,  "CCI Momentum Threshold", minval=0,   maxval=200, group="CCI")

// ── ADX 趨勢過濾（最佳化：ADX≥15）──
i_adxLength = input.int(14,   "ADX Length",    minval=5,  maxval=50, group="ADX FILTER")
i_adxMin    = input.int(15,   "ADX Min Trend", minval=0,  maxval=50, group="ADX FILTER")
i_useADX    = input.bool(true, "Enable ADX",   group="ADX FILTER")

// ── MFI ──
i_mfiLength = input.int(14, "MFI Length", minval=5, maxval=50, group="MFI")

// ── EMA（最佳化：趨勢50 追蹤30）──
i_emaTrend = input.int(50, "EMA Trend",    minval=10, maxval=200, group="EMA")
i_emaTrail = input.int(30, "Trailing EMA", minval=5,  maxval=100, group="EMA")

// ── ATR（最佳化：SL=2.5 TP=2.8）──
i_atrPeriod = input.int(14,   "ATR Period",             minval=5,   maxval=50,   group="ATR")
i_atrSL     = input.float(2.5, "ATR Stop Loss",         minval=0.5, maxval=5.0,  step=0.1, group="ATR")
i_atrTP     = input.float(2.8, "ATR Trail Activation",  minval=1.0, maxval=10.0, step=0.1, group="ATR")

// ── 過濾器（最佳化：Score≥5 SlowTh=50 CD=2）──
i_minScore     = input.int(5,     "Min Score (3~5)",        minval=3,  maxval=5,   group="FILTERS")
i_minATR       = input.float(5.0, "Min ATR",                minval=0,  maxval=100, step=1.0, group="FILTERS")
i_cooldownBars = input.int(2,     "Cooldown Bars",          minval=0,  maxval=20,  group="FILTERS")
i_cciSlowTh    = input.int(50,    "CCI Slow Min Magnitude", minval=0,  maxval=200, group="FILTERS")

// ═══════════════════════════════════════════════
//  指標
// ═══════════════════════════════════════════════

cciFast = ta.cci(close, i_cciFast)
cciMid  = ta.cci(close, i_cciMid)
cciSlow = ta.cci(close, i_cciSlow)

emaTrend = ta.ema(close, i_emaTrend)
emaTrail = ta.ema(close, i_emaTrail)
atrValue = ta.atr(i_atrPeriod)

// ADX
[diplus, diminus, adxValue] = ta.dmi(i_adxLength, i_adxLength)
adxOK = not i_useADX or adxValue >= i_adxMin

// MFI
hasTrueVolume = ta.cum(volume) > 0
trueMFI = ta.mfi(hlc3, i_mfiLength)

pseudoDir   = (high - low) != 0 ? (close - open) / (high - low) : 0.0
pseudoMag   = high - low
pseudoPos   = pseudoDir > 0 ? pseudoDir * pseudoMag : 0.0
pseudoNeg   = pseudoDir < 0 ? math.abs(pseudoDir) * pseudoMag : 0.0
pseudoPosMA = ta.sma(pseudoPos, i_mfiLength)
pseudoNegMA = ta.sma(pseudoNeg, i_mfiLength)
pseudoTotal = pseudoPosMA + pseudoNegMA
pseudoMFI   = pseudoTotal > 0 ? (pseudoPosMA / pseudoTotal) * 100 : 50.0
mfiValue    = hasTrueVolume ? trueMFI : pseudoMFI

// ATR 過濾
atrOK = atrValue >= i_minATR

// ═══════════════════════════════════════════════
//  Cooldown
// ═══════════════════════════════════════════════
var int barsSinceExit = 999

if strategy.position_size == 0
    barsSinceExit += 1
else
    barsSinceExit := 0

if strategy.position_size == 0 and strategy.position_size[1] != 0
    barsSinceExit := 0

cooldownOK = barsSinceExit >= i_cooldownBars

// ═══════════════════════════════════════════════
//  進場條件
// ═══════════════════════════════════════════════

// ── 做多 ──
longCCI1  = ta.crossover(cciFast, 0) and cciFast > i_cciThreshold
longCCI2  = cciMid > 0
longCCI3  = cciSlow > i_cciSlowTh
longTrend = close > emaTrend
longMFI   = mfiValue > 40

longScore = (longCCI1 ? 1 : 0) + (longCCI2 ? 1 : 0) + (longCCI3 ? 1 : 0) + (longTrend ? 1 : 0) + (longMFI ? 1 : 0)
longEntry = longScore >= i_minScore and longCCI1 and atrOK and cooldownOK and adxOK

// ── 做空 ──
shortCCI1  = ta.crossunder(cciFast, 0) and cciFast < -i_cciThreshold
shortCCI2  = cciMid < 0
shortCCI3  = cciSlow < -i_cciSlowTh
shortTrend = close < emaTrend
shortMFI   = mfiValue < 60

shortScore = (shortCCI1 ? 1 : 0) + (shortCCI2 ? 1 : 0) + (shortCCI3 ? 1 : 0) + (shortTrend ? 1 : 0) + (shortMFI ? 1 : 0)
shortEntry = shortScore >= i_minScore and shortCCI1 and atrOK and cooldownOK and adxOK

// ── 平倉信號 ──
exitLongSignal  = ta.crossunder(cciFast, 0)
exitShortSignal = ta.crossover(cciFast, 0)

// ═══════════════════════════════════════════════
//  追蹤止盈
// ═══════════════════════════════════════════════
var float entryPrice        = na
var float stopLossPrice     = na
var bool  trailingActive    = false
var float trailingStopPrice = na
var float entryATR          = na

if strategy.position_size > 0
    floatPnl = close - entryPrice
    tpDist   = entryATR * i_atrTP
    if not trailingActive and floatPnl >= tpDist
        trailingActive    := true
        trailingStopPrice := emaTrail
    if trailingActive
        trailingStopPrice := math.max(nz(trailingStopPrice), emaTrail)

else if strategy.position_size < 0
    floatPnl = entryPrice - close
    tpDist   = entryATR * i_atrTP
    if not trailingActive and floatPnl >= tpDist
        trailingActive    := true
        trailingStopPrice := emaTrail
    if trailingActive
        trailingStopPrice := math.min(nz(trailingStopPrice, 1e10), emaTrail)

else
    trailingActive    := false
    trailingStopPrice := na

// ═══════════════════════════════════════════════
//  策略執行
// ═══════════════════════════════════════════════

if longEntry and inDateRange and strategy.position_size == 0
    sl = close - atrValue * i_atrSL
    strategy.entry("Long", strategy.long)
    strategy.exit("Long SL", "Long", stop=sl)
    entryPrice        := close
    stopLossPrice     := sl
    entryATR          := atrValue
    trailingActive    := false
    trailingStopPrice := na

if shortEntry and inDateRange and strategy.position_size == 0
    sl = close + atrValue * i_atrSL
    strategy.entry("Short", strategy.short)
    strategy.exit("Short SL", "Short", stop=sl)
    entryPrice        := close
    stopLossPrice     := sl
    entryATR          := atrValue
    trailingActive    := false
    trailingStopPrice := na

// 追蹤止盈平倉
if strategy.position_size > 0 and trailingActive and not na(trailingStopPrice)
    if low <= trailingStopPrice
        strategy.close("Long", comment="Trail TP")

if strategy.position_size < 0 and trailingActive and not na(trailingStopPrice)
    if high >= trailingStopPrice
        strategy.close("Short", comment="Trail TP")

// CCI 信號平倉
if strategy.position_size > 0 and exitLongSignal
    strategy.close("Long", comment="CCI Exit")

if strategy.position_size < 0 and exitShortSignal
    strategy.close("Short", comment="CCI Exit")

// ═══════════════════════════════════════════════
//  視覺化
// ═══════════════════════════════════════════════
plot(emaTrend, "EMA Trend", color=color.new(color.orange, 30), linewidth=2)
plot(emaTrail, "EMA Trail", color=color.new(color.gray, 50), linewidth=1, style=plot.style_stepline)
plot(trailingActive ? trailingStopPrice : na, "Trailing Stop", color=color.new(color.lime, 0), linewidth=2, style=plot.style_stepline)

plotshape(longEntry  and strategy.position_size == 0 and inDateRange, "Long",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(shortEntry and strategy.position_size == 0 and inDateRange, "Short", shape.triangledown, location.abovebar, color.new(color.red, 0),   size=size.small)

// 趨勢背景
trendBull = cciFast > 0 and cciMid > 0 and cciSlow > i_cciSlowTh and adxOK
trendBear = cciFast < 0 and cciMid < 0 and cciSlow < -i_cciSlowTh and adxOK
bgcolor(trendBull ? color.new(color.green, 93) : trendBear ? color.new(color.red, 93) : na, title="Trend BG")
bgcolor(i_useADX and adxValue < i_adxMin ? color.new(color.gray, 95) : na, title="Ranging")

// 儀表板
var table infoTbl = table.new(position.top_right, 3, 8, bgcolor=color.new(color.black, 85), border_width=1)
if barstate.islast
    table.cell(infoTbl, 0, 0, "Indicator",  text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 0, "Value",      text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 2, 0, "Status",     text_color=color.white, text_size=size.small)

    table.cell(infoTbl, 0, 1, "CCI 14", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 1, str.tostring(cciFast, "#.0"), text_color=cciFast > 0 ? color.green : color.red, text_size=size.small)
    table.cell(infoTbl, 2, 1, math.abs(cciFast) > i_cciThreshold ? "Strong" : "Weak", text_color=math.abs(cciFast) > i_cciThreshold ? color.green : color.gray, text_size=size.small)

    table.cell(infoTbl, 0, 2, "CCI 25", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 2, str.tostring(cciMid, "#.0"), text_color=cciMid > 0 ? color.green : color.red, text_size=size.small)
    table.cell(infoTbl, 2, 2, cciMid > 0 ? "Bull" : "Bear", text_color=cciMid > 0 ? color.green : color.red, text_size=size.small)

    table.cell(infoTbl, 0, 3, "CCI 80", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 3, str.tostring(cciSlow, "#.0"), text_color=cciSlow > 0 ? color.green : color.red, text_size=size.small)
    table.cell(infoTbl, 2, 3, math.abs(cciSlow) > i_cciSlowTh ? "Aligned" : "Neutral", text_color=math.abs(cciSlow) > i_cciSlowTh ? color.green : color.gray, text_size=size.small)

    table.cell(infoTbl, 0, 4, "ADX", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 4, str.tostring(adxValue, "#.0"), text_color=adxOK ? color.green : color.orange, text_size=size.small)
    table.cell(infoTbl, 2, 4, adxOK ? "Trending" : "Ranging", text_color=adxOK ? color.green : color.orange, text_size=size.small)

    table.cell(infoTbl, 0, 5, "MFI", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 5, str.tostring(mfiValue, "#.0"), text_color=mfiValue > 50 ? color.green : color.red, text_size=size.small)
    table.cell(infoTbl, 2, 5, mfiValue > 50 ? "Inflow" : "Outflow", text_color=mfiValue > 50 ? color.green : color.red, text_size=size.small)

    table.cell(infoTbl, 0, 6, "ATR", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 6, str.tostring(atrValue, "#.0"), text_color=atrOK ? color.green : color.gray, text_size=size.small)
    table.cell(infoTbl, 2, 6, atrOK ? "Active" : "Low Vol", text_color=atrOK ? color.green : color.gray, text_size=size.small)

    table.cell(infoTbl, 0, 7, "Trail", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 7, trailingActive ? "ON" : "OFF", text_color=trailingActive ? color.lime : color.gray, text_size=size.small)
    table.cell(infoTbl, 2, 7, trailingActive ? str.tostring(trailingStopPrice, "#.0") : "-", text_color=color.white, text_size=size.small)

// Alerts
alertcondition(longEntry and strategy.position_size == 0, title="Long Entry", message="CCI v4b LONG")
alertcondition(shortEntry and strategy.position_size == 0, title="Short Entry", message="CCI v4b SHORT")
