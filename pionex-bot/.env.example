# Pionex API credentials
PIONEX_API_KEY=your_api_key_here
PIONEX_API_SECRET=your_api_secret_here

# Trading configuration
SYMBOL=BTC_USDT_PERP
FAST_MA_PERIOD=7
SLOW_MA_PERIOD=25
KLINE_INTERVAL=15M

# Risk management
MAX_POSITION_SIZE=0.01
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
MAX_DAILY_LOSS_PCT=5.0

# System
LOG_LEVEL=INFO
DRY_RUN=true
